# SRTAPP environment template (repo root)
# Copy to `.env` in this directory before `docker compose up`.
# Variables here are substituted into `docker-compose.yml` (e.g. DB_PASSWORD, REDIS_PASSWORD).

# ── DJANGO ────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-50-character-random-string-in-production
JWT_SECRET_KEY=change-this-to-a-different-50-character-random-string
ENVIRONMENT=development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── DATABASE (matches Postgres service defaults unless overridden) ──
DB_NAME=srtapp_db
DB_USER=srtapp_user
DB_PASSWORD=srtapp_pass
DB_HOST=db
DB_PORT=5432
DB_SSL_MODE=prefer

# ── REDIS ─────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_pass@redis:6379/2

# ── MINIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=srtapp-media

# ── MEILISEARCH ───────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=master_key

# ── PAYMENTS ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── NOTIFICATIONS ─────────────────────────────────────────
FCM_SERVER_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_API_KEY=

# ── SENTRY ────────────────────────────────────────────────
SENTRY_DSN=

# ── NEXT.JS (also set in compose for the frontend container) ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
JWT_SECRET=change-this-to-match-JWT_SECRET_KEY-above

# ── EXPO / MOBILE ─────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_PROJECT_ID=
