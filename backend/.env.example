# ── RUNTIME ───────────────────────────────────────────────
# Local-only overrides. Docker Compose loads secrets from the repo-root `.env`
# (see `/.env.example`) and passes env vars into containers — keep using this
# file when running Django on the host with SQLite/Postgres outside Compose.
DJANGO_SETTINGS_MODULE=config.settings.development

# ── DJANGO ────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-long-secret-key-here-min-50-chars
JWT_SECRET_KEY=your-different-jwt-secret-key-here-min-50-chars
ENVIRONMENT=development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── DATABASE ──────────────────────────────────────────────
DB_NAME=srtapp_db
DB_USER=srtapp_user
DB_PASSWORD=your-strong-db-password
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=prefer

# ── REDIS ─────────────────────────────────────────────────
# Hybrid dev: if Postgres/Redis run via `docker compose` (scripts/start-local-deps.sh),
# use the same passwords as repo-root `.env` / Compose defaults — e.g. DB_PASSWORD=srtapp_pass,
# REDIS_PASSWORD=redis_pass — and URLs below with `:password@`:
# REDIS_URL=redis://:redis_pass@127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://:redis_pass@127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://:redis_pass@127.0.0.1:6379/2
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MINIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=srtapp-media

# ── MEILISEARCH ───────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-key

# ── PAYMENTS ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── NOTIFICATIONS ─────────────────────────────────────────
FCM_SERVER_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_API_KEY=

# ── SENTRY ────────────────────────────────────────────────
SENTRY_DSN=
